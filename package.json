{
  "name": "clean-bookmarks",
  "version": "1.2.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "sync-models": "tsx scripts/sync-models.ts",
    "build-manifest": "tsx scripts/build-manifest.ts",
    "prebuild": "npm run sync-models && npm run build-manifest",
    "build": "tsx build.ts",
    "typecheck": "tsc --noEmit",
    "zip": "zip -r clean-bookmarks-v${npm_package_version}.zip dist/",
    "release": "release-it"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/chrome": "latest",
    "@types/node": "latest",
    "esbuild": "^0.24.0",
    "release-it": "^20.2.0",
    "sharp": "^0.33.0",
    "tsx": "^4.19.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.78.0",
    "zod": "^4.4.3"
  }
}
