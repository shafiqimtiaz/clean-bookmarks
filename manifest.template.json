{
  "manifest_version": 3,
  "name": "Clean Bookmarks",
  "version": "0.0.0.1",
  "version_name": "0.0.0.1",
  "description": "Organize your bookmarks with AI. Local-first: uses your own API key, zero telemetry, no developer access to your data.",
  "homepage_url": "https://github.com/shafiq-imtiaz/clean-bookmarks",
  "minimum_chrome_version": "120",

  "permissions": ["bookmarks", "storage"],
  "optional_host_permissions": [],

  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },

  "action": {
    "default_title": "Clean Bookmarks"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
